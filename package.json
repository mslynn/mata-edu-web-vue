    "@wangeditor/editor-for-vue": "^5.1.12",
    "axios": "^1.13.2",
    "crypto-js": "^4.2.0",
    "element-plus": "^2.11.8",
    "fabric": "^6.9.1",
    "gsap": "^3.14.2",
    "jsencrypt": "^3.3.2",
    "nuxt": "^4.2.1",
    "peerjs": "^1.5.4",
    "pinia": "^3.0.4",
    "vue": "^3.5.25",
    "vue-i18n": "^11.2.7",
    "vue-router": "^4.6.3"
  },
